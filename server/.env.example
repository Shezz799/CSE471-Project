# Copy to .env and fill in values (never commit .env)

PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB — use Atlas URI (direct hosts often work better than mongodb+srv behind some DNS)
MONGO_URI=

JWT_SECRET=

# Google Sign-In (must match client VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Credits / bKash (Module 3) ---

# Local faculty demo: same order + ledger flow as production, no bKash HTTP calls
# Accepted as true: true, 1, yes, on (case-insensitive)
BKASH_DEMO_MODE=true

# Instant fake purchase (dev only). Set false in any shared environment.
ALLOW_CREDIT_PURCHASE_SIMULATE=false

# Real bKash Tokenized Checkout (sandbox or live) — use bKash developer docs for keys/URLs
BKASH_TOKENIZE_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta/tokenized
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=

# Public HTTPS origin of THIS API (no path). bKash redirects browser to {origin}/callback
BKASH_CALLBACK_ORIGIN=
